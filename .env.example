# ============================================================
# CCMS Application Environment Configuration
#
# LOCAL DEVELOPMENT:
#   Copy this file to .env in the same directory (project root):
#     cp .env.example .env
#   Then edit .env with your values. Docker Compose reads .env
#   automatically for ${VARIABLE} substitution.
#
# HOSTINGER VPS DEPLOYMENT:
#   No .env file needed. Set these values in Hostinger's
#   Environment Variables section instead.
# ============================================================
#
# .env file location for local development:
#   /home/aditya/projects/cspl/SERVER_CCMS_UI_App/.env
#
# NOTE: Variables with a ✅ default are optional (safe fallback exists).
# Variables marked 🔴 REQUIRED must be provided or the stack will fail.
#
# All values below are examples — replace with your own.

# ----------------- MySQL -----------------
# 🔴 REQUIRED - MySQL root password
MYSQL_ROOT_PASSWORD=CHANGE_ME
# ✅ MySQL database name (default: employee_db)
MYSQL_DATABASE=employee_db

# ----------------- MongoDB -----------------
# No authentication enabled by default in this stack.
# ✅ MongoDB database name (default: ccms)
MONGODB_DATABASE=ccms
# ✅ MongoDB auth (leave empty if no auth configured)
MONGODB_USERNAME=
MONGODB_PASSWORD=

# ----------------- SERVER (Spring Boot, Netty) -----------------
# ✅ SERVER HTTP port (default: 8102)
SERVER_PORT=8102
# ✅ SERVER context path (default: /user)
SERVER_CONTEXT_PATH=/user
# ✅ MongoDB service hostname (default: mongodb)
MONGODB_HOST=mongodb
# ✅ MongoDB port (default: 27017)
MONGODB_PORT=27017
# ✅ Netty TCP port for DCUs (default: 9100)
NETTY_PORT=9100

# ----------------- CCMS UI (Tomcat) -----------------
# ✅ Tomcat HTTP port (default: 8080)
TOMCAT_PORT=8080
# ✅ WAR context path (default: /)
APP_CONTEXT=/
# ✅ Hostname of the SERVER service inside the docker network (default: server)
CCMS_SERVER_HOST=server

# ----------------- Internal HTTP (UI -> SERVER) -----------------
# ✅ Backend HTTP port (default: 8102, should match SERVER_PORT)
BACKEND_HTTP_PORT=8102
# ✅ Backend HTTP context (default: /user, should match SERVER_CONTEXT_PATH)
BACKEND_HTTP_CONTEXT=/user

# ----------------- Users (synced into MongoDB on every seed) -----------------
# JSON array of users to sync into the ccms_user_details collection.
# - On every seed run, each entry is inserted ONLY if no user with the
#   same email already exists (so passwords changed via the UI are
#   preserved across restarts).
# - To force a password reset: either delete the user from MongoDB
#   first, or change their email in this list.
#
# Fields:
#   email          (required) - becomes MongoDB _id
#   password       (required) - stored plaintext (current app behavior)
#   role           (default "USER")
#   first_name     (default "")
#   last_name      (default "")
#   district,mandal,gp (default "ALL")
#   all_privileges (default false) - if true, grants all 13 UI permissions
#
# NOTE: Do NOT wrap the JSON in single or double quotes.
#       SMOKE_ADMIN_PASSWORD must match the password in USERS_JSON.
SMOKE_ADMIN_EMAIL=admin@example.com
SMOKE_ADMIN_PASSWORD=CHANGE_ME
USERS_JSON=[{"email":"admin@example.com","password":"CHANGE_ME","role":"SUPER ADMIN","first_name":"Admin","last_name":"User","all_privileges":true}]

# ----------------- Logging -----------------
# ✅ Directory the SERVER JVM will write logs into (log4j2 file appender)
SERVER_LOG_DIR=/home/CCMS/roadmap/logs

# ----------------- Seeding -----------------
# ✅ Set to 'true' (default) to auto-restore MongoDB from db/seeds/mongo.archive
# and apply db/seeds/mysql/01-schema.sql on first 'docker compose up'.
# Set to 'false' to skip (use when restoring from your own backup).
SEED_DATA=true
