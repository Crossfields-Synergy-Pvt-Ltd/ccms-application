# ============================================================
# CCMS Application Environment Configuration - TEMPLATE
# Copy this file to .env and fill in your own values:
#   cp .env.example .env
# .env is gitignored; this file is committed.
# ============================================================

# ----------------- MySQL -----------------
MYSQL_ROOT_PASSWORD=CHANGE_ME
MYSQL_DATABASE=employee_db

# ----------------- MongoDB -----------------
# No authentication enabled by default in this stack.
MONGODB_DATABASE=ccms
MONGODB_USERNAME=
MONGODB_PASSWORD=

# ----------------- SERVER (Spring Boot, Netty) -----------------
SERVER_PORT=8102
SERVER_CONTEXT_PATH=/user
MONGODB_HOST=mongodb
MONGODB_PORT=27017
NETTY_PORT=9100

# ----------------- CCMS UI (Tomcat) -----------------
TOMCAT_PORT=8080
APP_CONTEXT=/CCMS
# Hostname of the SERVER service inside the docker network
CCMS_SERVER_HOST=server

# ----------------- Internal HTTP (UI -> SERVER) -----------------
BACKEND_HTTP_PORT=8102
BACKEND_HTTP_CONTEXT=/user

# ----------------- Smoke-test / Users (synced into MongoDB on every seed) -----------------
# JSON array of users to sync into the ccms_user_details collection.
# - On every seed run, each entry is inserted ONLY if no user with the
#   same email already exists (so passwords changed via the UI are
#   preserved across restarts).
# - To force a password reset: either delete the user from MongoDB
#   first, or change their email in this list.
#
# Fields:
#   email          (required) - becomes MongoDB _id
#   password       (required) - stored plaintext (current app behavior)
#   role           (default "USER")
#   first_name     (default "")
#   last_name      (default "")
#   dist,mondal,gp (default "ALL")
#   all_privileges (default false) - if true, grants all 13 UI permissions
SMOKE_ADMIN_EMAIL=admin@example.com
SMOKE_ADMIN_PASSWORD=CHANGE_ME
USERS_JSON='[{"email":"admin@example.com","password":"CHANGE_ME","role":"SUPER ADMIN","first_name":"Admin","last_name":"User","all_privileges":true}]'

# ----------------- Public deployment -----------------
PUBLIC_DOMAIN=ccms.example.com
LETSENCRYPT_LIVE_DIR=/etc/letsencrypt/live/ccms.example.com

# ----------------- Logging -----------------
# Directory the SERVER JVM will write logs into (log4j2 file appender).
SERVER_LOG_DIR=/home/CCMS/roadmap/logs

# ----------------- Seeding -----------------
# Set to 'true' (default) to auto-restore MongoDB from db/seeds/mongo.archive
# and apply db/seeds/mysql/01-schema.sql on first 'docker compose up'.
# Set to 'false' to skip (use when restoring from your own backup).
SEED_DATA=true
